{
  "$comment": "GitView Color E-Ink TextMate theme. On Kaleido 3 (muted, lower-PPI color), syntax is conveyed by WEIGHT / ITALIC / UNDERLINE and near-black ink — NOT pastel hues. Load this in the Sora editor when DisplayProfile == COLOR_EINK. Standard profile uses a normal colored theme instead.",
  "name": "GitView E-Ink Mono",
  "type": "light",
  "colors": {
    "editor.background": "#FFFFFF",
    "editor.foreground": "#111111",
    "editorLineNumber.foreground": "#777777",
    "editor.selectionBackground": "#CCCCCC"
  },
  "tokenColors": [
    { "scope": ["comment"], "settings": { "foreground": "#555555", "fontStyle": "italic" } },
    { "scope": ["keyword", "storage", "keyword.control"], "settings": { "foreground": "#000000", "fontStyle": "bold" } },
    { "scope": ["string", "constant.character"], "settings": { "foreground": "#222222", "fontStyle": "underline" } },
    { "scope": ["entity.name.function", "support.function"], "settings": { "foreground": "#000000", "fontStyle": "bold" } },
    { "scope": ["entity.name.type", "support.type", "support.class"], "settings": { "foreground": "#111111", "fontStyle": "bold underline" } },
    { "scope": ["variable", "variable.parameter"], "settings": { "foreground": "#111111" } },
    { "scope": ["constant.numeric", "constant.language"], "settings": { "foreground": "#111111", "fontStyle": "italic" } },
    { "scope": ["invalid"], "settings": { "foreground": "#000000", "fontStyle": "bold underline" } }
  ]
}
