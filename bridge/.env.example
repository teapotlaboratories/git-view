# Copy to .env and fill in. NEVER commit .env. These secrets stay on the bridge.

# The Claude API key. Held only by the bridge; never sent to the phone.
ANTHROPIC_API_KEY=sk-ant-...

# Secret used to sign/verify device bearer tokens (Phase 4). Generate a long random string.
DEVICE_TOKEN_SECRET=change-me-to-a-long-random-string

# Phase 0/dev only: a single static token the app must send as `Authorization: Bearer <token>`.
# Replaced by paired per-device tokens in Phase 4.
BRIDGE_TOKEN=dev-only-shared-token

# Where the bridge listens.
PORT=8787
HOST=127.0.0.1
