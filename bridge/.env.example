# GitView bridge environment. Copy to .env (or export in your shell) as needed.

# Path to the YAML config (default ./config.yaml). Also settable as argv[2].
GITVIEW_CONFIG=./config.yaml

# For the LOCAL-SDK provider only (API-key path). Leave UNSET for the remote-control provider —
# Remote Control rejects API keys and uses your claude.ai subscription OAuth instead.
# ANTHROPIC_API_KEY=sk-ant-...

# Optional: relocate Claude's config/session store. The bridge never parses this directory's
# internal *.jsonl files — it uses the SDK's listSessions()/resume APIs (see docs/DECISIONS.md).
# CLAUDE_CONFIG_DIR=~/.claude
