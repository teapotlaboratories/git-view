#!/bin/sh
# gitview-bridgectl — manage the GitView bridge systemd service.
#
# Read-only actions (status/health/version/config) run as you; privileged actions
# (pair/start/stop/restart/logs) re-exec via sudo when you are not root.
set -eu

SERVICE="gitview-bridge"
CONFIG="${GITVIEW_CONFIG:-/etc/gitview-bridge/config.yaml}"
SUDO=""
[ "$(id -u)" -eq 0 ] || SUDO="sudo"

# --- config-derived connection info (defaults if unreadable) ---
_port() { grep -oE '^[[:space:]]*port:[[:space:]]*[0-9]+' "$CONFIG" 2>/dev/null | grep -oE '[0-9]+' | tail -1; }
_bind() { grep -oE '^[[:space:]]*bind:[[:space:]]*[^[:space:]#]+' "$CONFIG" 2>/dev/null | awk '{print $2}' | tail -1; }
port() { p="$(_port)"; echo "${p:-8787}"; }
# 0.0.0.0 isn't dialable — hit loopback.
host() { b="$(_bind)"; b="${b:-127.0.0.1}"; [ "$b" = "0.0.0.0" ] && b="127.0.0.1"; echo "$b"; }
base() { echo "http://$(host):$(port)"; }

usage() {
  cat <<EOF
gitview-bridgectl — manage the GitView bridge service

Usage: gitview-bridgectl <command>

  status            service state + bound address + version + /v1/health
  pair              mint & print a FRESH pairing code (reload, no restart)
  health            GET /v1/health (JSON)
  start|stop|restart
  logs [-f]         journalctl for the service (-f follows)
  config            print the config path
  version           installed bridge version
  help              this text

Config: $CONFIG   (edit with: sudo \$EDITOR $CONFIG, then: gitview-bridgectl restart)
EOF
}

cmd="${1:-status}"
[ $# -gt 0 ] && shift || true

case "$cmd" in
  status)
    $SUDO systemctl status "$SERVICE" --no-pager --lines=0 || true
    echo
    echo "  bind:    $(_bind 2>/dev/null || echo '?'):$(port)"
    echo "  base:    $(base)"
    echo "  version: $(grep -oE '\"version\"[^,]*' /opt/gitview-bridge/package.json 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || echo '?')"
    printf '  health:  '
    curl -fsS --max-time 3 "$(base)/v1/health" 2>/dev/null || echo "unreachable"
    echo
    ;;
  pair)
    $SUDO systemctl reload "$SERVICE"
    sleep 1
    code="$($SUDO journalctl -u "$SERVICE" -n 40 --no-pager 2>/dev/null \
      | grep -aiE 'pairing code' | grep -aoE '[A-Z0-9]{4}-[A-Z0-9]{4}-[A-Z0-9]{2,}' | tail -1)"
    if [ -n "$code" ]; then
      echo "Pairing code (valid until it rotates): $code"
    else
      echo "Reloaded, but couldn't read the code from the log — try: gitview-bridgectl logs"
      exit 1
    fi
    ;;
  health)  curl -fsS "$(base)/v1/health" 2>/dev/null && echo || { echo "unreachable"; exit 1; } ;;
  start|stop|restart) $SUDO systemctl "$cmd" "$SERVICE"; echo "$SERVICE $cmd: done" ;;
  logs)
    if [ "${1:-}" = "-f" ]; then $SUDO journalctl -u "$SERVICE" -f
    else $SUDO journalctl -u "$SERVICE" -n 100 --no-pager; fi ;;
  config)  echo "$CONFIG" ;;
  version) grep -oE '\"version\"[^,]*' /opt/gitview-bridge/package.json 2>/dev/null | grep -oE '[0-9]+\.[0-9]+\.[0-9]+' || { echo "unknown"; exit 1; } ;;
  -h|--help|help) usage ;;
  *) echo "unknown command: $cmd" >&2; echo; usage; exit 1 ;;
esac
